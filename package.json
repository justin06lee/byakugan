{
  "name": "@justin06lee/byakugan",
  "version": "0.1.0",
  "description": "Token-efficient, render-truthful browser perception for LLM agents — the model only sees what the user can see",
  "type": "module",
  "license": "MIT",
  "author": "Justin Lee <tenet.sh@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justin06lee/byakugan.git"
  },
  "keywords": [
    "llm",
    "agent",
    "browser",
    "cdp",
    "chromium",
    "playwright",
    "electron",
    "accessibility",
    "computer-use",
    "token-efficiency"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./transports": {
      "types": "./dist/transports.d.ts",
      "import": "./dist/transports.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "m0": "tsx scripts/m0.ts",
    "bench": "tsx scripts/bench.ts",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "playwright": "^1.61.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
